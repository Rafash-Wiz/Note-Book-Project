# Ignore everything at the repo root by default.
*

# Keep git metadata, this ignore file, and the repo README.
!.gitignore
!README.md

# Track the actual project folder.
!Note-Book-App/
!Note-Book-App/**

# Ignore generated files inside the project.
Note-Book-App/node_modules/
Note-Book-App/dist/
Note-Book-App/.vite/
Note-Book-App/.DS_Store
Note-Book-App/.env
Note-Book-App/.env.*
Note-Book-App/*.log
